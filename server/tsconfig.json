{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../src/features/game/types.ts",
    "../src/features/game/roles.ts",
    "../src/features/game/rules.ts",
    "../src/features/game/game-machine.ts"
  ]
}
